cmake_minimum_required(VERSION 3.16)
project(phoneos C)

set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)

option(PHONEOS_WSL "Build a native SDL2 launcher for WSL" OFF)

if(NOT CMAKE_BUILD_TYPE)
    set(CMAKE_BUILD_TYPE Release)
endif()

if(PHONEOS_WSL)
    include(FetchContent)

    FetchContent_Declare(
        lvgl
        GIT_REPOSITORY https://github.com/lvgl/lvgl.git
        GIT_TAG v8.3.11
        GIT_SHALLOW TRUE
    )

    FetchContent_MakeAvailable(lvgl)
    add_library(phoneos_lvgl INTERFACE)
    target_link_libraries(phoneos_lvgl INTERFACE lvgl)
    set(PHONEOS_LVGL_TARGET phoneos_lvgl)
    set(PHONEOS_LVDRIVERS_TARGET)
else()
    find_package(PkgConfig QUIET)

    if(PkgConfig_FOUND)
        pkg_check_modules(LVGL QUIET lvgl)
        pkg_check_modules(LVDRIVERS QUIET lv_drivers)
    endif()

    if(NOT LVGL_FOUND)
        message(FATAL_ERROR "lvgl was not found. Install the lvgl development package or enable PHONEOS_WSL.")
    endif()

    add_library(phoneos_lvgl INTERFACE)
    target_include_directories(phoneos_lvgl INTERFACE ${LVGL_INCLUDE_DIRS})
    target_link_libraries(phoneos_lvgl INTERFACE ${LVGL_LIBRARIES})
    set(PHONEOS_LVGL_TARGET phoneos_lvgl)

    if(LVDRIVERS_FOUND)
        add_library(phoneos_lvdrivers INTERFACE)
        target_include_directories(phoneos_lvdrivers INTERFACE ${LVDRIVERS_INCLUDE_DIRS})
        target_link_libraries(phoneos_lvdrivers INTERFACE ${LVDRIVERS_LIBRARIES})
        set(PHONEOS_LVDRIVERS_TARGET phoneos_lvdrivers)
    else()
        message(FATAL_ERROR "lv_drivers was not found. Install the lv_drivers development package.")
    endif()
endif()

add_subdirectory(system/framework)
add_subdirectory(apps)
add_subdirectory(services)
add_subdirectory(ui/launcher)